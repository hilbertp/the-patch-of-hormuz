ANTHROPIC_API_KEY=your-key-here

# Feature flag — gate flow vs legacy direct-to-main merge
# 0 = legacy: ACCEPTED slices merge directly to main (current pre-Bashir behavior)
# 1 = gate flow: ACCEPTED slices squash to dev; Bashir regression gates dev → main
# Default: 0. Flip to 1 only after Bashir manual-trigger wiring is complete.
DS9_USE_GATE_FLOW=0
