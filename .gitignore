# macOS
.DS_Store
**/.DS_Store

# Runtime artifacts (generated by watcher at runtime)
.bridge/bridge.log
.bridge/heartbeat.json

# Node
node_modules/
*.log
npm-debug.log*
yarn-debug.log*

# Queue runtime state (managed by watcher, not source code)
bridge/queue/*.md
bridge/queue/*.json
!bridge/queue/.gitkeep

# Error JSON records (written by watcher at runtime)
bridge/errors/*.json
!bridge/errors/.gitkeep

# Register log — append-only runtime file, not source code
bridge/register.jsonl

# Environment
.env
.env.*
!.env.example
bridge/nog-active.json
bridge/wormhole-heartbeat.json

# Nog review logs (runtime, not source)
bridge/logs/

# Kira event drain — append-only runtime file
bridge/kira-events.jsonl

# Worktree rescue artifacts (created at runtime on no_report failures)
bridge/worktree-rescue/

# RESTAGED bootstrap marker — written once per install, workspace-local
bridge/.restaged-bootstrap-done

# Main-lock state marker — transient, written by unlock-main.sh, removed by lock-main.sh
bridge/.main-unlocked
