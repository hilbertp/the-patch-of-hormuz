.bridge/bridge.log
.bridge/heartbeat.json

# Node
node_modules/
*.log
npm-debug.log*
yarn-debug.log*

# Queue runtime state (managed by watcher, not source code)
bridge/queue/*.md
bridge/queue/*.json
!bridge/queue/.gitkeep

# Environment
.env
.env.*
!.env.example
